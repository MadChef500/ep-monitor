# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Notion integration token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The ID of your "EliteProspects Monitoring Log" database
# Found in the database URL: notion.so/username/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
